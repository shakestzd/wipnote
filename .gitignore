# wipnote policy
# Track canonical declarative project state under .wipnote/:
# - work-item HTML/YAML content
# - project config/metadata
# - archive HTML when intentionally retained as part of repo history
#
# Ignore only derived storage/index artifacts and runtime telemetry.

# wipnote derived database/index/cache artifacts
.wipnote/*.db*
.wipnote/.db/
.wipnote/*.sqlite*
.wipnote/archive-index/
*.bloom

# wipnote runtime/session telemetry
.wipnote/events/
.wipnote/sessions/
.wipnote/logs/
.wipnote/**/*.jsonl
.wipnote/**/*.log
.wipnote/**/*.lock
.wipnote/.active-session
.wipnote/.launch-mode
.wipnote/.session-warning-state.json
.wipnote/parent-activity.json
.wipnote/.error-spikes.json
.wipnote/active-auto-spikes.json
.wipnote/drift-queue.json
.wipnote/.otlp-port
.wipnote/.serve.lock

# wipnote obsolete/generated analytics artifacts from older builds
.wipnote/cigs/
.wipnote/insights/
.wipnote/metrics/
.wipnote/orchestrator-mode.json

# wipnote invalid nested state
.wipnote/.wipnote/

# wipnote tracked canonical content should override broad global ignores
!.wipnote/**/*.html
!.wipnote/**/*.yaml
!.wipnote/**/*.yml
!.wipnote/**/*.css

# Legacy HtmlGraph derived/runtime artifacts may still exist in old checkouts.
.htmlgraph/*.db*
.htmlgraph/.db/
.htmlgraph/*.sqlite*
.htmlgraph/archive-index/
.htmlgraph/events/
.htmlgraph/sessions/
.htmlgraph/logs/
.htmlgraph/**/*.jsonl
.htmlgraph/**/*.log
.htmlgraph/**/*.lock
.htmlgraph/.active-session
.htmlgraph/.launch-mode
.htmlgraph/.session-warning-state.json
.htmlgraph/parent-activity.json
.htmlgraph/.error-spikes.json
.htmlgraph/active-auto-spikes.json
.htmlgraph/drift-queue.json
.htmlgraph/.otlp-port
.htmlgraph/.serve.lock
.htmlgraph/cigs/
.htmlgraph/insights/
.htmlgraph/metrics/
.htmlgraph/orchestrator-mode.json
.htmlgraph/.htmlgraph/
!.htmlgraph/**/*.html
!.htmlgraph/**/*.yaml
!.htmlgraph/**/*.yml
!.htmlgraph/**/*.css

.env

# MkDocs build output
site/

# pdoc generated documentation
docs/api-pdoc/
docs/api/*.html
docs/api/*.js

.contextune/

# Prevent root clutter from accumulating
# Screenshots and temp images
*.png
# One-off scratch/test files
*.txt
!requirements*.txt
# Coverage artifacts
coverage.json
# Session state
.session-warning-state.json
# Marimo sessions
__marimo__/
# UV cache
.uv-cache/
# Mypy cache
.mypy_cache/

# Build artifacts
_build/
archive/
packages/go-plugin/hooks/bin/
hooks/bin/
plugin/hooks/bin/htmlgraph
/htmlgraph

# Notebook files copied at build time from prototypes/ (do not commit)
internal/notebook/files/
dist/
_build/tailwind-*
chrome/*.zip

# Subagent worktrees (transient; created by Claude Code Agent tool)
.claude/worktrees/

# Go test scratch space (used to avoid /tmp noexec in devcontainers)
.test-exec/
.test-tmp/
.gotmp/
.tmp-go/
.tmp-gotest/
tmp/go-tmp/
tmp/gotmp.*/
.build-cache/
