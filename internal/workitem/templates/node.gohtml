<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="wipnote-version" content="1.0">
    <title>{{.Title}}</title>
    <link rel="stylesheet" href="../styles.css">
</head>
<body>
    <article id="{{.ID}}"
             data-type="{{.Type}}"
             data-status="{{.Status}}"
             data-priority="{{.Priority}}"
             data-created="{{.CreatedAt}}"
             data-updated="{{.UpdatedAt}}"
{{- if .AgentAssigned}} data-agent-assigned="{{.AgentAssigned}}"{{end}}
{{- if .TrackID}} data-track-id="{{.TrackID}}"{{end}}
{{- if .SpikeSubtype}} data-spike-subtype="{{.SpikeSubtype}}"{{end}}
{{- if .ClaimedAt}} data-claimed-at="{{.ClaimedAt}}"{{end}}
{{- if .ClaimedBySession}} data-claimed-by-session="{{.ClaimedBySession}}"{{end}}
{{- if .CreatedByAgent}} data-created-by-agent="{{.CreatedByAgent}}"{{end}}
{{- if .CreatedByModel}} data-created-by-model="{{.CreatedByModel}}"{{end}}
{{- if .CreatedByRole}} data-created-by-role="{{.CreatedByRole}}"{{end}}
{{- if .CreatedByCLIVersion}} data-created-by-cli-version="{{.CreatedByCLIVersion}}"{{end}}>

        <header>
            <h1>{{.Title}}</h1>
            <div class="metadata">
                <span class="badge status-{{.Status}}">{{.StatusLabel}}</span>
                <span class="badge priority-{{.Priority}}">{{.PriorityLabel}} Priority</span>
            </div>
        </header>
{{- if .HasEdges}}

        <nav data-graph-edges>
{{- range .EdgeGroups}}
            <section data-edge-type="{{.RelType}}">
                <h3>{{.RelLabel}}:</h3>
                <ul>
{{- range .Edges}}
                    <li><a href="{{.TargetID}}.html" data-relationship="{{.Relationship}}"{{if .HasSince}} data-since="{{.Since}}"{{end}}>{{.Label}}</a></li>
{{- end}}
                </ul>
            </section>
{{- end}}
        </nav>
{{- end}}
{{- if .HasSteps}}

        <section data-steps>
            <h3>Implementation Steps</h3>
            <ol>
{{- range .Steps}}
                <li data-completed="{{.CompletedStr}}"
{{- if .StepID}} data-step-id="{{.StepID}}"{{end}}
{{- if .Agent}} data-agent="{{.Agent}}"{{end}}
{{- if .DependsOnStr}} data-depends-on="{{.DependsOnStr}}"{{end}}
{{- if .Agent}} data-created-by-agent="{{.Agent}}"{{end}}
{{- if .CreatedByModel}} data-created-by-model="{{.CreatedByModel}}"{{end}}
{{- if .CreatedByRole}} data-created-by-role="{{.CreatedByRole}}"{{end}}
{{- if .CreatedByCLIVersion}} data-created-by-cli-version="{{.CreatedByCLIVersion}}"{{end}}>{{.Icon}} {{.Description}}</li>
{{- end}}
            </ol>
        </section>
{{- end}}
{{- if .HasContent}}

        <section data-content>
            <h3>Description</h3>
            {{.TrustedContent}}
        </section>
{{- end}}
    </article>
</body>
</html>
