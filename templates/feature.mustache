<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="wipnote-version" content="1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="{{stylesheet_path}}">
</head>
<body>
    <article id="{{id}}"
             data-type="feature"
             data-status="{{status}}"
             data-priority="{{priority}}"
             data-created="{{created_at}}"
             data-updated="{{updated_at}}"{{#agent_assigned}} data-agent-assigned="{{agent_assigned}}"{{/agent_assigned}}{{#track_id}} data-track-id="{{track_id}}"{{/track_id}}{{#context_tokens}} data-context-tokens="{{context_tokens}}"{{/context_tokens}}{{#context_peak}} data-context-peak="{{context_peak}}"{{/context_peak}}{{#context_cost}} data-context-cost="{{context_cost}}"{{/context_cost}}{{#spike_subtype}} data-spike-subtype="{{spike_subtype}}"{{/spike_subtype}}{{#auto_generated}} data-auto-generated="{{auto_generated}}"{{/auto_generated}}{{#session_id}} data-session-id="{{session_id}}"{{/session_id}}{{#from_feature_id}} data-from-feature-id="{{from_feature_id}}"{{/from_feature_id}}{{#to_feature_id}} data-to-feature-id="{{to_feature_id}}"{{/to_feature_id}}{{#model_name}} data-model-name="{{model_name}}"{{/model_name}}>

        <header>
            <h1>{{title}}</h1>
            <div class="metadata">
                <span class="badge status-{{status}}">{{status_display}}</span>
                <span class="badge priority-{{priority}}">{{priority_display}} Priority</span>
            </div>
        </header>
{{#has_edges}}

        <nav data-graph-edges>
{{#edge_groups}}
            <section data-edge-type="{{relationship}}">
                <h3>{{relationship_display}}:</h3>
                <ul>
{{#edges}}
                    <li><a href="{{href}}" data-relationship="{{relationship}}"{{#since}} data-since="{{since}}"{{/since}}>{{title}}</a></li>
{{/edges}}
                </ul>
            </section>
{{/edge_groups}}
        </nav>
{{/has_edges}}
{{#has_steps}}
        <section data-steps>
            <h3>Implementation Steps</h3>
            <ol>
{{#steps}}
                <li data-completed="{{completed}}"{{#step_id}} data-step-id="{{step_id}}"{{/step_id}}{{#agent}} data-agent="{{agent}}"{{/agent}}{{#depends_on}} data-depends-on="{{depends_on}}"{{/depends_on}}>{{icon}} {{description}}</li>
{{/steps}}
            </ol>
        </section>
{{/has_steps}}
{{#has_content}}
        <section data-content>
            <h3>Description</h3>
            <p>{{content}}</p>
        </section>
{{/has_content}}
    </article>
</body>
</html>
