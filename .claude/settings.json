{
  "permissions": {
    "allow": [
      "Write(**)",
      "Edit(**)",
      "NotebookEdit(**)",
      "Bash(cd packages/go*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)"
    ],
    "deny": [
      "Write(.htmlgraph/**)",
      "Edit(.htmlgraph/**)",
      "NotebookEdit(.htmlgraph/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh -c '$HOME/.claude/omp-claude-wrapper.sh'",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "plansDirectory": ".htmlgraph/plans/",
  "claudeMdExcludes": [
    "AGENTS.md"
  ]
}
